# ── 데이터베이스 ──────────────────────────────────────────────
# 운영에서는 강력한 비밀번호로 교체할 것.
DB_PASSWORD=change-me-strong-db-password

# ── 임베딩 모델 ───────────────────────────────────────────────
# 임베딩 모델과 차원은 함께 맞춰야 한다 (변경 시 DB 볼륨 초기화 필요).
#   nomic-embed-text → 768 / all-minilm → 384
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── MinIO root(관리) 계정 ─────────────────────────────────────
# 부트스트랩/관리 전용. 애플리케이션은 절대 root를 쓰지 않는다.
# 기본 minioadmin/minioadmin 은 운영에서 반드시 교체.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-root-password

# ── 스코프 서비스 계정 (root 분리) ────────────────────────────
# mcp-server 가 사용할 읽기 전용 계정 (pdfs 버킷 GetObject/ListBucket 만).
MINIO_READONLY_KEY=mcp-readonly
MINIO_READONLY_SECRET=change-me-readonly-secret
# 외부 업로더가 사용할 업로드 계정 (pdfs 버킷 Put/Get/Delete).
MINIO_UPLOAD_KEY=pdf-uploader
MINIO_UPLOAD_SECRET=change-me-upload-secret

# ── 외부 도메인 (Caddy 경유) ──────────────────────────────────
# 실제 운영 도메인으로 교체. Caddy가 이 도메인으로 자동 HTTPS를 발급한다.
MINIO_API_DOMAIN=files.example.com
MINIO_CONSOLE_DOMAIN=console.example.com
# presigned/share URL의 공통 호스트 (S3 API 도메인, https).
MINIO_SERVER_URL=https://files.example.com
# 콘솔 리다이렉트 URL.
MINIO_BROWSER_REDIRECT_URL=https://console.example.com
